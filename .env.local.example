# Supabase (erforderlich)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Admin (nur lokal - niemals in Vercel als NEXT_PUBLIC_ setzen)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Verschlüsselung für API-Tokens in der Datenbank (PROJ-3)
# Generieren mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-64-char-hex-key-here

# PROJ-11: Kostenübernahme-Antrag (E-Mail-Versand via Resend)
RESEND_API_KEY=re_your-resend-api-key-here
RESEND_FROM_EMAIL=CBS Förderverein <noreply@cbs-mannheim.de>

# PROJ-11: Token-Signierung für Genehmigungslinks
# Generieren mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APPROVAL_TOKEN_SECRET=your-64-char-hex-key-here

# PROJ-11: Erlaubte iFrame-Origins (kommagetrennt)
IFRAME_ALLOWED_ORIGINS=https://cbs-mannheim.de

# Öffentliche Site-URL (für E-Mail-Links)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# PROJ-16: Enable Banking API (PSD2-Bankabruf)
# Registrierung & App anlegen unter: https://enablebanking.com
# Die Application ID steht im Enable-Banking-Control-Panel.
ENABLEBANKING_APP_ID=bf41e3db-581b-4029-b7c2-c5dbad77f999
ENABLEBANKING_API_URL=https://api.enablebanking.com
# ASPSP = Bank. Namen findet man via GET /aspsps?country=DE.
ENABLEBANKING_ASPSP_NAME=BBBank
ENABLEBANKING_ASPSP_COUNTRY=DE
# Entweder Pfad zur PEM-Datei (lokal entwickeln) ...
ENABLEBANKING_PRIVATE_KEY_PATH=.secrets/enablebanking-sandbox.pem
# ... oder Inline-Version (Vercel). Setze entweder PATH oder PRIVATE_KEY,
# nicht beides. Auf Vercel mit literalen \n-Sequenzen zwischen den Zeilen:
# ENABLEBANKING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Gültigkeit der Bank-Zustimmung in Tagen (Default 180, max. je nach Bank)
ENABLEBANKING_CONSENT_TAGE=180

# PROJ-16: Schutz für Vercel Cron-Endpoint /api/cron/psd2-abruf
# Generieren mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-64-char-hex-secret-here
